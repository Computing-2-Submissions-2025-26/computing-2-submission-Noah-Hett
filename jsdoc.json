{
    "source": {
        "include": [
            "web-app/Domino.js",
            "web-app/Board.js",
            "web-app/Scoring.js",
            "web-app/Game.js",
            "web-app/Module.js"
        ],
        "includePattern": "\\.js$",
        "excludePattern": "(node_modules/|docs)"
    },
    "opts": {
        "encoding": "utf8",
        "destination": "out/",
        "recurse": true,
        "verbose": true
    }
}
